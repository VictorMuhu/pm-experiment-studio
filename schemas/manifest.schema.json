{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "manifest.schema.json",
  "title": "Project Manifest",
  "description": "Metadata schema for a published project in /projects",
  "type": "object",
  "required": [
    "name",
    "slug",
    "status",
    "category",
    "description",
    "problem",
    "created",
    "updated",
    "tags",
    "has_demo",
    "demo_url",
    "screenshot"
  ],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Display name of the project"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "description": "URL-safe identifier matching the folder name"
    },
    "status": {
      "type": "string",
      "enum": ["prototype", "stable", "archived"],
      "description": "Current development status"
    },
    "category": {
      "type": "string",
      "enum": ["tool", "ui-experiment", "research", "data", "generator", "other"],
      "description": "Project category for filtering and display"
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "maxLength": 160,
      "description": "One sentence description — no trailing period"
    },
    "problem": {
      "type": "string",
      "minLength": 10,
      "description": "The specific problem this project addresses"
    },
    "created": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "ISO 8601 creation date"
    },
    "updated": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "ISO 8601 date of last meaningful update"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
      },
      "description": "Lowercase hyphenated tags for search and filtering"
    },
    "has_demo": {
      "type": "boolean",
      "description": "Whether a live demo is available"
    },
    "demo_url": {
      "type": ["string", "null"],
      "format": "uri",
      "description": "URL to live demo, or null"
    },
    "screenshot": {
      "type": ["string", "null"],
      "description": "Relative path to primary screenshot, or null"
    },
    "tech": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Tech stack used — optional"
    },
    "notes": {
      "type": ["string", "null"],
      "description": "Optional freeform notes — not displayed publicly"
    }
  }
}
